# Copie para .env (não versionado) ou defina no painel do host (Render, etc.)

# Obrigatório em produção (Render): ≥ 32 caracteres aleatórios
# SECRET_KEY=

# Produção: senha do master (não use só o padrão do código)
# MASTER_USERNAME=
# MASTER_PASSWORD=

# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# CORS (opcional): https://app.exemplo.com,https://outro.com
# CORS_ORIGINS=

# Backup por e-mail (opcional; master aciona na UI)
# BACKUP_SMTP_HOST=smtp.gmail.com
# BACKUP_SMTP_PORT=587
# BACKUP_SMTP_USER=
# BACKUP_SMTP_PASSWORD=
# BACKUP_EMAIL_TO=
